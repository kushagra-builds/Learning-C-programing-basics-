#include<stdio.h>
int main(){

float units=0.0;
float bill;

printf("Enter the units: ");
scanf("%f",&units);

if(units < 0){
    printf("You entered invalid number of units!\n");
}
else if(units<=100){
    bill=units*5;
    printf("The total bill of the entered units is: %.2f\n",bill);
}
else if(units<=200){
    bill=100*5+(units-100)*7;
    printf("The total bill of the entered units is: %.2f\n",bill);
}
else{
    bill=(100*5)+(100*7)+(units-200)*10;
    printf("The total bill of the entered units is: %.2f\n",bill);
}

return 0;
}
