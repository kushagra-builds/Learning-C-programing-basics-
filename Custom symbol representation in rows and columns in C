#include<stdio.h>
int main(){
    int row=0;
    int column=0;
    char symbol='\0';

    printf("Enter the number of rows: ");
    scanf("%d",&row);
    printf("Enter the number of column: ");
    scanf("%d",&column);
    printf("Enter the symbol: ");
    scanf(" %c",&symbol);

    for(int i=0;i<row;i++){
        for(int j=0;j<column;j++){
            printf("%c",symbol);
        }
        printf("\n");
    }
    return 0;
}
