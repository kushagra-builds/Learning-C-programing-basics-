#include<stdio.h>
int main(){

int score=0;
printf("Enter your score(0-100): ");
scanf("%d",&score);

if(score<0 ||score>100){
    printf("It is an invalid score!\n");
}
else if(score>=90){
    printf("You obtained grade A!\n");
}
else if(score>=75 && score<=89){
    printf("You obtained grade B!\n");
}
else if(score>=50 && score<=74){
    printf("You obtained grade C!\n");
}
else{
    printf("You have failed!\n");
}
return 0;
}
