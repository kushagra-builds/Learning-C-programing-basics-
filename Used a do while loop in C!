#include<stdio.h>
#include<stdbool.h>
int main(){
    bool isRunning=true;
    char response='\0';

    do{
        printf("You are playing a game!\n");
        printf("Would you like to continue(Y or N): ");
        scanf(" %c",&response);

        if(response != 'Y' && response != 'y'){
            isRunning=false;
            printf("You are not playing!\n");
            printf("You exited the game!\n");
        }
    }while(isRunning);
    return 0;
}
